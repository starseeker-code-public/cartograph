# Repo-root build context (infra/caddy/web.Dockerfile). Keep host build
# artifacts and junk out of images — a stray node_modules/ or .venv/ copied
# over a fresh lockfile install silently unpins dependency versions.
.git
**/node_modules
**/dist
**/.venv
**/__pycache__
**/.pytest_cache
**/.mypy_cache
**/.ruff_cache
**/*.tsbuildinfo
**/.env
**/.env.*
!**/.env.example
scripts/osm/*.pbf
backups
