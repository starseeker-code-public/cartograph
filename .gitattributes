# Normalize line endings to LF in the repo; checkout as-is on all platforms.
* text=auto eol=lf

# Shell scripts must be LF for Linux containers.
*.sh text eol=lf

# Windows batch files need CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files.
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.pbf binary
